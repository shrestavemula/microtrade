# ══════════════════════════════════════════════════════════════
# MICROTRADE CONFIGURATION
# ══════════════════════════════════════════════════════════════

# ── Alpaca API ───────────────────────────────────────────────
# Sign up at https://alpaca.markets
# Paper trading (fake money) keys: https://app.alpaca.markets/paper/dashboard/overview
# Live trading keys: https://app.alpaca.markets/dashboard/overview
#
# ⚠️  START WITH PAPER TRADING! Set ALPACA_PAPER=true below.

ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_PAPER=true

# ── Server ───────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173

# ── Optional: News API ───────────────────────────────────────
# Free tier at https://newsapi.org (500 requests/day)
NEWS_API_KEY=
