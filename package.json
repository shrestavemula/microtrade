{
  "name": "microtrade",
  "version": "1.0.0",
  "description": "Bloomberg Terminal-inspired AI trading bot for small trades under $100",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "setup": "npm install && cp .env.example .env && echo '✅ Setup complete! Edit .env with your Alpaca keys, then run: npm run dev'"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "lightweight-charts": "^4.1.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "vite": "^5.1.0"
  }
}
